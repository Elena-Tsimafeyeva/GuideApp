<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GuideApp"
             x:Class="GuideApp.WayPage"
             NavigationPage.HasNavigationBar="False"
             Title="WayPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <VerticalStackLayout Grid.Row="0" Padding="10" Margin="0,15,0,0">
            <Label Text="Выберите путь" FontSize="18" HorizontalOptions="Center"/>
            <Picker Title="Нажмите для выбора" FontSize="18" ItemsSource="{Binding Ways}" SelectedItem="{Binding SelectedWay}" />
        </VerticalStackLayout>
        <CollectionView Grid.Row="1" ItemsSource="{Binding DisplayedArticles}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button Text="{Binding Title}" BackgroundColor="ForestGreen" Margin="0,5" Command="{Binding BindingContext.OpenArticleCommand, 
                        Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <controls:MainPanel Grid.Row="2" Background="MintCream"/>
    </Grid>
</ContentPage>