<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GuideApp"
             x:Class="GuideApp.WayPage"
             Title="WayPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <VerticalStackLayout Grid.Row="0" Grid.RowSpan="6">
            <Label x:Name="header" Text="Выберите путь" FontSize="18" />
            <Picker Title = "Путь">
                <Picker.Items>
                    <x:String>Путь 1</x:String>
                    <x:String>Путь 2</x:String>
                </Picker.Items>
            </Picker>
        </VerticalStackLayout>
        <controls:MainPanel Grid.Row="6" Background="MintCream"/>
    </Grid>
</ContentPage>