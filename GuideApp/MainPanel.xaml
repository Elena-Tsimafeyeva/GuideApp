<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GuideApp.MainPanel">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Button
            ImageSource="map.png" Grid.Column="0" CornerRadius="0" BackgroundColor="MintCream" Margin="5,0,5,0" Command="{Binding OpenMapCommand}"/>
        <Button 
            ImageSource="track.png" Grid.Column="1" CornerRadius="0" BackgroundColor="MintCream" Margin="5,0,5,0" Command="{Binding ChooseWayCommand}"/>
        <Button 
            ImageSource="search.png" Grid.Column="2" CornerRadius="0" BackgroundColor="MintCream" Margin="5,0,5,0" Command="{Binding SearchInfoCommand}"/>
        <Button 
            ImageSource="qrcode.png" Grid.Column="3" CornerRadius="0" BackgroundColor="MintCream" Margin="5,0,5,0" Command="{Binding CameraQRCommand}"/>
        <Button 
            ImageSource="information.png" Grid.Column="4" CornerRadius="0" BackgroundColor="MintCream" Margin="5,0,5,0" Command="{Binding AdditionalInfoCommand}"/>
        
    </Grid>
</ContentView>
