<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GuideApp"
             xmlns:local="clr-namespace:GuideApp.ViewModel"
             x:Class="GuideApp.SearchPage"
             Title="SearchPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <VerticalStackLayout Grid.Row="0">
            <!--<SearchBar Placeholder="Поиск..."/>-->
            <!--Search articles-->
            <SearchBar 
                Placeholder="Поиск..."
                Text="{Binding SearchText}"
                SearchCommand="{Binding SearchCommand}"/>
            <CollectionView ItemsSource="{Binding SearchResults}" IsVisible="{Binding SearchResults.Count}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Button 
                            Text="{Binding Title}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenArticleCommand}"
                            CommandParameter="{Binding .}" 
                            BackgroundColor="LimeGreen"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
            <!-- Кнопки разделов -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,5">
            <Button Text="  Тема 1  " Command="{Binding LoadSectionCommand}" WidthRequest="100" HeightRequest="50" BackgroundColor="ForestGreen" Margin="10,0,10,0">
                <Button.CommandParameter>
                    <x:Int32>1</x:Int32>
                </Button.CommandParameter>
            </Button>
            <Button Text="  Тема 2  " Command="{Binding LoadSectionCommand}" WidthRequest="100" HeightRequest="50" BackgroundColor="ForestGreen" Margin="10,0,10,0">
                <Button.CommandParameter>
                    <x:Int32>2</x:Int32>
                </Button.CommandParameter>
            </Button>
            <!--<Button Text="Обновить базу"
        Clicked="OnUpdateDatabaseClicked"
        BackgroundColor="LightBlue"
        TextColor="Black"
        HorizontalOptions="Center"
        Margin="10"/>-->
        </HorizontalStackLayout>
        </VerticalStackLayout>
        <ScrollView Grid.Row="1" Grid.RowSpan="2">
            <!-- Список статей -->
            <CollectionView ItemsSource="{Binding Articles}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Button 
                            BackgroundColor="ForestGreen" 
                            Margin="0,5,0,5" 
                            Text="{Binding Title}"
                            Command="{Binding BindingContext.OpenArticleCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                            CommandParameter="{Binding .}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
        <controls:MainPanel Background="MintCream" Grid.Row="6"/>
    </Grid>
</ContentPage>