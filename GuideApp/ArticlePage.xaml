<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GuideApp"
             x:Class="GuideApp.ArticlePage"
             Title="ArticlePage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ScrollView Grid.Row="0" Grid.RowSpan="4">
            <VerticalStackLayout HorizontalOptions="Center">
                <Label Text="Title"/>
                <Image Source="forest1.jpg"/>
                <Label Text="Text Text Text"/>
                <Label Text="There will be audio here."/>
            </VerticalStackLayout>
        </ScrollView>
        <controls:MainPanel Background="LightGreen" Grid.Row="4"/>
    </Grid>
</ContentPage>